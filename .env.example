# Application
NODE_ENV=development
PORT=3000
APP_NAME=nf-processor

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nf_user
DB_PASSWORD=nf_password
DB_DATABASE=nf_processor
DB_POOL_SIZE=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_IDEMPOTENCY_TTL=86400

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=nf_user
RABBITMQ_PASSWORD=nf_password
RABBITMQ_VHOST=nf_processor
RABBITMQ_PREFETCH=10

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nf-xmls
S3_FORCE_PATH_STYLE=true

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=1h

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Email (IMAP)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_TLS=true
IMAP_ENABLED=false

# SQS (S3 Events)
SQS_QUEUE_URL=
SQS_REGION=us-east-1
SQS_ENABLED=false

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nf-processor
LOG_LEVEL=debug
